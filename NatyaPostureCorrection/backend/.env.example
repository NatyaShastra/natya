# Backend configuration
UPLOAD_DIR=/tmp/natya_uploads
RESULTS_DIR=/tmp/natya_results

# MediaPipe model configuration
# You must provide a valid MediaPipe Pose Landmarker `.task` model file.
# Example: /workspaces/natya/NatyaPostureCorrection/backend/models/pose_landmarker.task
POSE_LANDMARKER_MODEL_PATH=

# Google Drive / GCS configuration (public URLs)
# Example: https://storage.googleapis.com/your-bucket/steps/
REFERENCE_VIDEO_BASE_URL=

# OpenAI configuration (optional, used for narrative feedback)
OPENAI_API_KEY=

# Processing configuration
MAX_UPLOAD_MB=50
